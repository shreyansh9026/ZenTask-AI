# This bot is designed by Shreyansh Tripathi.

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
GUILD_ID=optional_for_instant_slash_updates

# Groq API Configuration (Free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# Web Search (Tavily - free tier at https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here
SEARCH_PROVIDER=tavily

# Database Configuration (Cloud Atlas or Local)
# MONGODB_URI=mongodb+srv://user:pass@cluster0... (Atlas)
MONGODB_URI=mongodb://localhost:27017/zentask

# Web Dashboard Settings
PORT=3000

# Bot Settings
BOT_PREFIX=!
MAX_TASKS_PER_USER=20
